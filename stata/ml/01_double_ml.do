/*==============================================================
  文件名：01_double_ml.do
  模型：  Double Machine Learning (近似流程)
  描述：  使用 Lasso 控制变量筛选后估计处理效应
  依赖：  lasso（Stata 内置）
  数据：  data/sample/firm_panel.dta
  作者：
  更新：  2025-05
==============================================================*/

* ---------------------------------------------------------------
* 0. 全局设置（使用者修改这里的路径）
* ---------------------------------------------------------------
global root  "C:/Users/yourname/empirlab"
global data  "$root/data/sample"
global out   "$root/output"

clear all
set more off
cd "$root"

* ---------------------------------------------------------------
* 1. 加载数据
* ---------------------------------------------------------------
use "$data/firm_panel.dta", clear

* ---------------------------------------------------------------
* 2. 数据预处理
* ---------------------------------------------------------------
drop if missing(y, d, x1, x2, x3)

* ---------------------------------------------------------------
* 3. 核心估计
* ---------------------------------------------------------------
lasso linear y x1 x2 x3
predict yhat, xb

lasso linear d x1 x2 x3
predict dhat, xb

gen y_tilde = y - yhat
gen d_tilde = d - dhat
reg y_tilde d_tilde, robust

* ---------------------------------------------------------------
* 4. 结果输出
* ---------------------------------------------------------------
capture which esttab
if _rc == 0 {
    esttab using "$out/01_double_ml.csv", replace
}

* ---------------------------------------------------------------
* 5. 稳健性检验
* ---------------------------------------------------------------
reg y_tilde d_tilde x1, robust
