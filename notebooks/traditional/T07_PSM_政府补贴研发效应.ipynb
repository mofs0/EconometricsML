   ],
   "source": [
    "for cal in [0.02, 0.05, 0.10, None]:\n",
    "    p2 = PSM(caliper=cal, n_neighbors=1)\n",
    "    p2.fit(X, T, Y)\n",
    "    s2 = p2.summary()\n",
    "    cal_str = str(cal) if cal else '无卡尺'\n",
    "    a2 = s2['ATT']\n",
    "    print(f'caliper={cal_str:6}  ATT={a2[\"coef\"]:.4f}  p={a2[\"p_value\"]:.4f}')"
   ]
