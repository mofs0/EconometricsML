      "caliper=0.02    ATT=0.3708  p=0.0000\n",
      "caliper=0.05    ATT=0.3759  p=0.0000\n",
      "caliper=0.1     ATT=0.3901  p=0.0000\n",
      "caliper=无卡尺     ATT=0.5435  p=0.0000\n"
     ]
