    "    print(f'  {k:8s}: coef={v[\"coef\"]:.6f}  z={v[\"z\"]:.3f}  p={v[\"p_value\"]:.4f}')\n",
    "print(f'\\n持续性(alpha+beta): {s[\"persistence\"]:.4f}')\n",
    "print(f'AIC={s[\"AIC\"]:.2f}  BIC={s[\"BIC\"]:.2f}')"
   ]
